    ],
    "catatan": "Nomor nasional (112, 110, 113, 115, 119) berlaku di SELURUH Indonesia. Nomor lokal adalah tambahan untuk akses langsung per daerah.",
    "cara_pakai_rag": "Gunakan koordinat GPS user → reverse geocode ke kota/kabupaten → match ke kota_id → tampilkan darurat lokal + nasional sebagai fallback."
  },
  "nomor_nasional": {
    "layer": "nasional",
    "description": "Nomor darurat nasional berlaku di SELURUH Indonesia, gratis 24 jam, bisa dipanggil tanpa pulsa dan saat HP terkunci.",
